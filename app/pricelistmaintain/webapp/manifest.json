{
  "_version": "1.81.0",
  "sap.app": {
    "id": "pricelistapp.pricelistmaintain",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.2",
      "toolsId": "134e640e-f763-4811-baef-d38de4e845d0"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/price-list/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "PriceMaintain-manage": {
          "semanticObject": "PriceMaintain",
          "action": "manage",
          "title": "Pricelist Maintenance",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.ui.table": {}
      }
    },
    "cache": {
      "mode": "off"
    },    
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "pricelistapp.pricelistmaintain.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "PricelistDataList",
          "target": "PricelistDataList"
        },
        {
          "pattern": "PricelistData({key}):?query:",
          "name": "PricelistDataObjectPage",
          "target": "PricelistDataObjectPage"
        }
      ],
      "targets": {
        "PricelistDataList": {
          "type": "Component",
          "id": "PricelistDataList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/PricelistData",
              "variantManagement": "Page",
              "navigation": {
                "PricelistData": {
                  "detail": {
                    "route": "PricelistDataObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "GridTable",
                    "enableMassEdit": false,
                    "creationMode": "Inline"
                  },
                  "actions": {
                    "duplicateRow": {
                      "press": "pricelistapp.pricelistmaintain.ext.controller.customActionController.onDuplicatePricelist",
                      "visible": true,
                      "enabled": true,
                      "requiresSelection": true,
                      "text": "Duplicate Record"
                    }
                  }
                }
              }
            }
          }
        },
        "PricelistDataObjectPage": {
          "type": "Component",
          "id": "PricelistDataObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/PricelistData",
              "content": {
                "body": {
                  "sections": {
                    "ProductsTree": {
                      "template": "pricelistapp.pricelistmaintain.ext.fragment.ProductsTree",
                      "position": {
                        "placement": "After",
                        "anchor": "PricelistInfoFacet"
                      },
                      "title": "Gallagher Products"
                    },
                    "ProductDetails": {
                      "template": "pricelistapp.pricelistmaintain.ext.fragment.ProductDetails",
                      "title": "Product Details",
                      "position": {
                        "placement": "After",
                        "anchor": "ProductsTree"
                      }
                    },
                    "TermsandConditions": {
                      "template": "pricelistapp.pricelistmaintain.ext.fragment.TermsandConditions",
                      "title": "Terms and Conditions",
                      "position": {
                        "anchor": "ProductDetails",
                        "placement": "After"
                      }
                    },
                    "GeneralNotes": {
                      "title": "Terms and Conditions (Section 3)",
                      "template": "pricelistapp.pricelistmaintain.ext.fragment.GeneralNotes",
                      "position": {
                        "placement": "After",
                        "anchor": "TermsandConditions"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ObjectPage.ObjectPageController": {
            "controllerName": "pricelistapp.pricelistmaintain.ext.controller.PricelistMaintainObjectPageExt"
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "priceListSystem.service"
  }
}
