<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:macros="sap.fe.macros" xmlns:smartForm="sap.ui.comp.smartform">
	<VBox id="VBox2" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/PricelistMainCategory'}">
		<smartForm:SmartForm id="MainCategoryForm" editable="true" >
			<smartForm:layout>
                <smartForm:ColumnLayout id="MainCategoryColumnsLayout" columnsM="2" columnsL="2" columnsXL="2" />
            </smartForm:layout>

			<smartForm:Group id="MainCategoryTermsAndCondGroup" title="Main Category Details">
                <smartForm:GroupElement id="MainCategoryGroupElement" label="Main Category Name">
					<Input id="MainCategoryInput" value="sub category test name"></Input>
                </smartForm:GroupElement>
				<smartForm:GroupElement id="MainCategoryNameGroupElement" label="Published Main Category Name">
					<Input id="PublishedMainCategoryInput" value="sub category published name"></Input>
                </smartForm:GroupElement>
            </smartForm:Group>

		</smartForm:SmartForm>
        
        <smartForm:SmartForm id="MainCategoryNotesForm" editable="true" >
            <smartForm:Group id="MainCategoryTermsAndCondContextGroup">
                <smartForm:GroupElement id="MainContextGroupElement" label="Terms and Conditions">
                    <TextArea 
                        id="MainCategoryTermsAndCondContextText" 
                        value="{Context}" 
                        maxLength="1000" 
                        rows="10"
                        width="60%" />
                </smartForm:GroupElement>
				<smartForm:GroupElement id="MainCategoryTermsDisableGroupElement" label="Disable">
					<HBox id="MainCategoryTermsExtUSerHBox" alignContent="Center">
                		<Text id="MainCategoryTermsExtUserText" text="External User" />
                		<Switch id="MainCategoryTermsExtUserSwitch" state="false" change=".onTermsDisableSwitchChange" />
						<Text id="MainCategoryTermsIntUserText" text="Internal User" class="sapUiMediumMarginBegin" />
                		<Switch id="MainCategoryTermsIntUserSwitch" state="false" change=".onTermsDisableSwitchChange" />
            		</HBox>
				</smartForm:GroupElement>
            </smartForm:Group>

            <smartForm:Group id="MainCategoryNoteGroup">
                <smartForm:GroupElement id="MainCategoryNotesGroupElement" label="Notes">
                    <TextArea 
                        id="MainCategoryGeneralNotesText" 
                        value="{generalNotes>/Notes}" 
                        maxLength="5000" 
                        rows="10"
                        width="100%" />
                </smartForm:GroupElement>
				<smartForm:GroupElement id="MainCategoryNotesDisableGroupElement" label="Disable">
					<HBox id="MainCategoryNotesExtUSerVBox" alignContent="Center">
                		<Text id="MainCategoryNotesExtUserText" text="External User" />
                		<Switch id="MainCategoryNotesExtUserSwitch" state="false" change=".onNotesDisableSwitchChange" />
						<Text id="MainCategoryNotesIntUserText" text="Internal User" class="sapUiMediumMarginBegin" />
                		<Switch id="MainCategoryNotesIntUserSwitch" state="false" change=".onNotesDisableSwitchChange" />
            		</HBox>
				</smartForm:GroupElement>
            </smartForm:Group>

        </smartForm:SmartForm>
	</VBox>
</core:FragmentDefinition>