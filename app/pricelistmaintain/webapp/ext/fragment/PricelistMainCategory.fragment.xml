<core:FragmentDefinition
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:macros="sap.fe.macros"
    xmlns:smartForm="sap.ui.comp.smartform">

    <VBox
        id="VBoxMainCategory"
        visible="{jsonModel>/showMainCategoryDetails}"
        core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/PricelistMainCategory'}">

        <smartForm:SmartForm id="MainCategoryForm" editable="true">
            <smartForm:layout>
                <smartForm:ColumnLayout
                    id="MainCategoryColumnsLayout"
                    columnsM="2"
                    columnsL="2"
                    columnsXL="2" />
            </smartForm:layout>

            <smartForm:Group id="MainCategoryTermsAndCondGroup" title=" ">
                <smartForm:GroupElement
                    id="MainCategoryGroupElement"
                    label="Main Category Name">
                    <Input
                        id="MainCategoryInput"
                        value="{jsonModel>/selectedMainCategory/Title}" 
                        editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>

                <smartForm:GroupElement
                    id="MainCategoryNameGroupElement"
                    label="Published Main Category Name">
                    <Input
                        id="PublishedMainCategoryInput"
                        value="{jsonModel>/selectedMainCategory/PublishedCategoryName}" 
                        editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>
            </smartForm:Group>
        </smartForm:SmartForm>

        <smartForm:SmartForm id="MainCategoryNotesForm" editable="true">
            <smartForm:Group id="MainCategoryTermsAndCondContextGroup">
                <smartForm:GroupElement
                    id="MainContextGroupElement"
                    label="Terms and Conditions">
                    <TextArea
                        id="MainCategoryTermsAndCondContextText"
                        value="{jsonModel>/selectedMainCategory/Description}"
                        maxLength="1000"
                        rows="10"
                        width="100%" 
                        editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>

                <smartForm:GroupElement
                    id="MainCategoryTermsDisableGroupElement"
                    label="Disable">
                    <HBox
                        id="MainCategoryTermsExtUserHBox"
                        alignContent="Center">
                        <Text
                            id="MainCategoryTermsExtUserText"
                            text="External User" />

                        <Switch
                            id="MainCategoryTermsExtUserSwitch"
                            state="{jsonModel>/selectedMainCategory/TermsDisableExtUser}"
                            change="handler.onTermsDisableSwitchChange" 
                            type="AcceptReject"
                            enabled="{ui>/isEditable}"/>

                        <Text
                            id="MainCategoryTermsIntUserText"
                            text="Internal User"
                            class="sapUiMediumMarginBegin" />

                        <Switch
                            id="MainCategoryTermsIntUserSwitch"
                            state="{jsonModel>/selectedMainCategory/TermsDisableIntUser}"
                            change="handler.onTermsDisableSwitchChange" 
                            type="AcceptReject"
                            enabled="{ui>/isEditable}"/>
                    </HBox>
                </smartForm:GroupElement>
            </smartForm:Group>

            <smartForm:Group id="MainCategoryNoteGroup">
                <smartForm:GroupElement
                    id="MainCategoryNotesGroupElement"
                    label="Notes">
                    <TextArea
                        id="MainCategoryGeneralNotesText"
                        value="{jsonModel>/selectedMainCategory/Notes}"
                        maxLength="5000"
                        rows="10"
                        width="100%" 
                        editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>

                <smartForm:GroupElement
                    id="MainCategoryNotesDisableGroupElement"
                    label="Disable">
                    <HBox
                        id="MainCategoryNotesExtUserHBox"
                        alignContent="Center">
                        <Text
                            id="MainCategoryNotesExtUserText"
                            text="External User" />

                        <Switch
                            id="MainCategoryNotesExtUserSwitch"
                            state="{jsonModel>/selectedMainCategory/NotesDisableExtUser}"
                            change="handler.onNotesDisableSwitchChange" 
                            type="AcceptReject"
                            enabled="{ui>/isEditable}"/>

                        <Text
                            id="MainCategoryNotesIntUserText"
                            text="Internal User"
                            class="sapUiMediumMarginBegin" />

                        <Switch
                            id="MainCategoryNotesIntUserSwitch"
                            state="{jsonModel>/selectedMainCategory/NotesDisableIntUser}"
                            change="handler.onNotesDisableSwitchChange" 
                            type="AcceptReject"
                            enabled="{ui>/isEditable}"/>
                    </HBox>
                </smartForm:GroupElement>
            </smartForm:Group>
        </smartForm:SmartForm>

    </VBox>
</core:FragmentDefinition>