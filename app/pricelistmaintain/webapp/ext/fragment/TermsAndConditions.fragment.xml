<core:FragmentDefinition 
    xmlns:core="sap.ui.core" 
    xmlns="sap.m" 
    xmlns:macros="sap.fe.macros" 
    xmlns:smartForm="sap.ui.comp.smartform">
	<VBox id="VBox4" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/TermsAndConditionsV2'}">
		
		<smartForm:SmartForm id="TermsAndCondForm" editable="true">
            
            <smartForm:layout>
                <smartForm:Layout 
                    id="TermsAndCondGridLayout" 
                    labelSpanXL="2" 
                    labelSpanL="2" 
                    labelSpanM="2" 
                    emptySpanXL="0" 
                    emptySpanL="0" 
                    emptySpanM="0" 
                    columnsXL="1" 
                    columnsL="1" 
                    columnsM="1" />
            </smartForm:layout>

            <smartForm:Group id="TermsAndConditionsGroup">
                
                <smartForm:GroupElement id="TermsAndCondGroupElement" label="Terms and Conditions">
                    <TextArea 
                        id="TermsAndCondContextText" 
                        value="{TermsAndConditions}" 
                        maxLength="1000" 
                        rows="6"
                        width="75%" />
                </smartForm:GroupElement>
                
                <smartForm:GroupElement id="TermsAndCondDisableGroupElement" label="Disable">
                    <HBox id="TermsAndCondExtUserHBox" alignItems="Center">
                        
                        <Text id="TermsAndCondDisableExtUserText" text="External User" class="sapUiTinyMarginEnd" />
                        <Switch id="TermsAndCondDisableExtUserSwitch" state="false" change=".onTACDisableSwitchChange" />
                        
                        <Text id="TermsAndCondDisableIntUserText" text="Internal User" class="sapUiLargeMarginBegin sapUiTinyMarginEnd" />
                        <Switch id="TermsAndCondDisableIntUserSwitch" state="false" change=".onTACDisableSwitchChange" />
                        
                    </HBox>
                </smartForm:GroupElement>

            </smartForm:Group>
        </smartForm:SmartForm>

	</VBox>
</core:FragmentDefinition>