<core:FragmentDefinition 
    xmlns:core="sap.ui.core" 
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form">
    
    <VBox id="VBox4" width="100%" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/TermsAndConditionsV2'}">

        <HBox id="TACHBox" alignItems="Start" width="100%" class="sapUiSmallMarginBottom">
            <HBox id="TACLabelHBox" justifyContent="End">
                <layoutData><FlexItemData id="TACLabelLayoutData" growFactor="1" maxWidth="7%" /></layoutData>
                <Label id="TACLabel" text="Terms and Conditions:" class="sapUiSmallMarginEnd sapUiSmallMarginTop" />
            </HBox>
            <TextArea 
                id="TermsAndCondContextText" 
                value="{TermsAndConditions}" 
                maxLength="1000" 
                rows="6"
                width="75%">
                <layoutData><FlexItemData id="TACContextTextLayoutData" growFactor="1" maxWidth="100%" /></layoutData>
            </TextArea>
        </HBox>

        <HBox id="TACDisableHBox" alignItems="Center" width="100%" class="sapUiSmallMarginBottom">
            <HBox id="TACDisableLabelHBox" justifyContent="End">
                <layoutData><FlexItemData id="TACDisableLabelLayoutData" growFactor="1" maxWidth="7%" /></layoutData>
                <Label id="TACDisableLabel" text="Disable:" class="sapUiSmallMarginEnd" />
            </HBox>
            <HBox id="TACDisableHBoxContent" alignItems="Center">
                <layoutData><FlexItemData id="TACDisableHBoxContentLayoutData" growFactor="1" maxWidth="100%" /></layoutData>
                <Text id="TermsAndCondDisableExtUserText" text="External User" class="sapUiTinyMarginEnd" />
                <Switch id="TermsAndCondDisableExtUserSwitch" state="false" change=".onTACDisableSwitchChange" />
                <Text id="TermsAndCondDisableIntUserText" text="Internal User" class="sapUiLargeMarginBegin sapUiTinyMarginEnd" />
                <Switch id="TermsAndCondDisableIntUserSwitch" state="false" change=".onTACDisableSwitchChange" />
            </HBox>
        </HBox>

    </VBox>
</core:FragmentDefinition>