<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m">
    <Dialog id="ColumnSettingsDialog" title="Show / Hide Columns" contentWidth="20%" verticalScrolling="true">
        <content>
            <VBox id="TreeTableColumnSettings" class="sapUiSmallMargin">
                <Toolbar id="ColumnSettingsToolbar" class="sapUiTinyMarginBottom">
                    <ToolbarSpacer id="TreeTableColumnSettingsSpacer"/>
                    <Button id="TreeTableColumnSettingsSelectAllButton" text="Select All" type="Transparent" press="onSelectAllColumns"/>
                    <Button id="TreeTableColumnSettingsDeselectAllButton" text="Deselect All" type="Transparent" press="onDeselectAllColumns"/>
                </Toolbar>

                <List id="ColumnSettingsList" items="{jsonModel>/columnSettings/columns}" mode="None">
                    <CustomListItem id="ColumnSettingsListItem" type="Active">
                        <HBox id="ColumnSettingsHBox" alignItems="Center" justifyContent="SpaceBetween" width="97%" class="sapUiTinyMarginBeginEnd sapUiTinyMarginTopBottom">
                            <Text id="ColumnSettingsText" text="{jsonModel>title}"/>
                            <CheckBox id="ColumnSettingsCheckBox" selected="{jsonModel>visible}"/>
                        </HBox>
                    </CustomListItem>
                </List>
            </VBox>
        </content>

        <beginButton>
            <Button id="TreeTableColumnSettingsApplyButton" text="Apply" type="Emphasized" press="onApplyColumnSettings"/>
        </beginButton>
        <endButton>
            <Button id="TreeTableColumnSettingsCloseButton" text="Close" press="onCloseColumnSettingsDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>