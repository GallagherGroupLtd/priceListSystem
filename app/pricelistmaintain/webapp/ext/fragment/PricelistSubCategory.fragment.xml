<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:macros="sap.fe.macros" xmlns:smartForm="sap.ui.comp.smartform">
    <VBox visible="{= !!${jsonModel>Title} }" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/PricelistSubCategory'}">

        <smartForm:SmartForm editable="{ui>/isEditable}">
            <smartForm:layout>
                <smartForm:ColumnLayout columnsM="2" columnsL="2" columnsXL="2" />
            </smartForm:layout>

            <smartForm:Group title=" ">
                <smartForm:GroupElement label="Sub Category Name">
                    <Input value="{jsonModel>Title}" editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>

                <smartForm:GroupElement label="Published Sub Category Name">
                    <Input value="{jsonModel>PublishedTitle}" editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>
            </smartForm:Group>
        </smartForm:SmartForm>

        <smartForm:SmartForm editable="{ui>/isEditable}">

            <smartForm:Group>
                <smartForm:GroupElement label="Terms and Conditions">
                    <TextArea
                        value="{jsonModel>Description}"
                        maxLength="1000"
                        rows="10"
                        width="100%" 
                        editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>

                <smartForm:GroupElement label="Disable">
                    <HBox alignContent="Center">
                        <Text text="External User" />
                        <Switch state="{jsonModel>TermsDisableExtUser}" change="handler.onTermsDisableSwitchChange" enabled="{ui>/isEditable}"/>

                        <Text text="Internal User" class="sapUiMediumMarginBegin" />
                        <Switch state="{jsonModel>TermsDisableIntUser}" change="handler.onTermsDisableSwitchChange" enabled="{ui>/isEditable}"/>
                    </HBox>
                </smartForm:GroupElement>
            </smartForm:Group>

            <smartForm:Group>
                <smartForm:GroupElement label="Notes">
                    <TextArea
                        value="{jsonModel>Notes}"
                        maxLength="5000"
                        rows="10"
                        width="100%" 
                        editable="{ui>/isEditable}"/>
                </smartForm:GroupElement>

                <smartForm:GroupElement 
                    id="SubCategoryNotesDisableGroupElement"
                    label="Disable">
                    <HBox 
                        id="SubCategoryNotesExtUserHBox"
                        alignContent="Center">
                        <Text 
                            id="SubCategoryNotesExtUserText"
                            text="External User" />

                        <Switch 
                            id="SubCategoryNotesExtUserSwitch"
                            state="{jsonModel>NotesDisableExtUser}" 
                            change="handler.onNotesDisableSwitchChange" 
                            enabled="{ui>/isEditable}"/>

                        <Text 
                            id="SubCategoryNotesIntUserText"
                            text="Internal User" 
                            class="sapUiSmallMarginBegin" />

                        <Switch 
                            id="SubategoryNotesIntUserSwitch"
                            state="{jsonModel>NotesDisableIntUser}" 
                            change="handler.onNotesDisableSwitchChange" 
                            enabled="{ui>/isEditable}"/>
                    </HBox>
                </smartForm:GroupElement>
            </smartForm:Group>

        </smartForm:SmartForm>

    </VBox>
</core:FragmentDefinition>