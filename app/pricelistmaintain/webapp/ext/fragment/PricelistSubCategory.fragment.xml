<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:macros="sap.fe.macros" xmlns:smartForm="sap.ui.comp.smartform">
	<VBox id="VBox3" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/PricelistSubCategory'}">

		<smartForm:SmartForm id="SubCategoryForm" editable="true" >
			<smartForm:layout>
                <smartForm:ColumnLayout id="columnsLayout" columnsM="2" columnsL="2" columnsXL="2" />
            </smartForm:layout>

			<smartForm:Group id="SubCategoryTermsAndCondGroup" title="Sub Category Details">
                <smartForm:GroupElement id="SubCategoryGroupElement" label="Sub Category Name">
					<Input id="subCategoryInput" value="sub category test name"></Input>
                </smartForm:GroupElement>
				<smartForm:GroupElement id="nameGroupElement" label="Published Sub Category Name">
					<Input id="publishedSubCategoryInput" value="sub category published name"></Input>
                </smartForm:GroupElement>
            </smartForm:Group>

		</smartForm:SmartForm>
        
        <smartForm:SmartForm id="SubCategoryNotesForm" editable="true" >
            <smartForm:Group id="SubCategoryTermsAndCondContextGroup">
                <smartForm:GroupElement id="ContextGroupElement" label="Terms and Conditions">
                    <TextArea 
                        id="SubCategoryTermsAndCondContextText" 
                        value="{Context}" 
                        maxLength="1000" 
                        rows="10"
                        width="100%" />
                </smartForm:GroupElement>
				<smartForm:GroupElement id="SubCategoryTermsDisableGroupElement" label="Disable">
					<HBox id="SubCategoryTermsExtUSerVBox" alignContent="Center">
                		<Text id="SubCategoryTermsExtUserText" text="External User" />
                		<Switch id="SubCategoryTermsExtUserSwitch" state="false" change=".onTermsDisableSwitchChange" />
						<Text id="SubCategoryTermsIntUserText" text="Internal User" class="sapUiMediumMarginBegin" />
                		<Switch id="SubCategoryTermsIntUserSwitch" state="false" change=".onTermsDisableSwitchChange" />
            		</HBox>
				</smartForm:GroupElement>
            </smartForm:Group>

            <smartForm:Group id="SubCategoryNoteGroup">
                <smartForm:GroupElement id="SubCategoryNotesGroupElement" label="Notes">
                    <TextArea 
                        id="SubCategoryGeneralNotesText" 
                        value="{generalNotes>/Notes}" 
                        maxLength="5000" 
                        rows="10"
                        width="100%" />
                </smartForm:GroupElement>
				<smartForm:GroupElement id="notesDisableGroupElement" label="Disable">
					<HBox id="notesExtUSerVBox" alignContent="Center">
                		<Text id="notesExtUserText" text="External User" />
                		<Switch id="notesExtUserSwitch" state="false" change=".onNotesDisableSwitchChange" />
						<Text id="notesIntUserText" text="Internal User" class="sapUiMediumMarginBegin" />
                		<Switch id="notesIntUserSwitch" state="false" change=".onNotesDisableSwitchChange" />
            		</HBox>
				</smartForm:GroupElement>
            </smartForm:Group>

        </smartForm:SmartForm>
		
	</VBox>
</core:FragmentDefinition>