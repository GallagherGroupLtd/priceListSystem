<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
>
	<Dialog
		id="customerSelectionDialog"
		title="Customer Number"
		type="Message"
		contentWidth="10%"
		afterClose="onCustomerSelectionDialogAfterClose"
	>
		<content>
			<Label
				text="Customer Number:"
				labelFor="customerNoInput"
				class="sapUiSmallMarginBottom"
			/>
			<Input
				id="customerNoInput"
				placeholder="Enter customer no"
				type="Text"
				liveChange="onCustomerNoLiveChange"
			/>
		</content>
		<beginButton>
			<Button
				type="Emphasized"
				text="Confirm"
				press="onCustomerSelectionConfirm"
			/>
		</beginButton>
		<endButton>
			<Button
				text="Cancel"
				press="onCustomerSelectionCancel"
			/>
		</endButton>
	</Dialog>
</core:FragmentDefinition>