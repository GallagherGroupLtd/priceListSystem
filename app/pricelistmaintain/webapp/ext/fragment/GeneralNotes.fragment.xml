<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:macros="sap.fe.macros">
	<VBox id="VBox" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/GeneralNotes'}">
		<Title id="GeneralNotesTitle" text="General Notes" level="H4" class="sapUiSmallMarginTop sapUiTextBold"/>
		<TextArea id="GeneralNotesText" value="{generalNotes>/Notes}" maxLength="5000" width="100%" class="sapUiSmallMarginTopBottom"/>
		<Title id="DisableTitle" text="Disable" level="H4" class="sapUiSmallMarginTop sapUiTextBold"/>
		<HBox id="switchHBox" width="100%">
			<HBox id="extUSerVBox">
				<Text id="extUserText" text="External User" class="sapUiTinyMarginTopBottom"/>
				<Switch id="extUserSwitch" state="false" class="sapUiSmallMarginBeginEnd" change=".onExternalUserSwitchChange">
					<layoutData>
						<FlexItemData id="extUserFlexData" growFactor="1" />
					</layoutData>
				</Switch>
			</HBox>
			<HBox id="intUSerVBox">
				<Text id="intUserText" text="Internal User" class="sapUiTinyMarginTopBottom"/>
				<Switch id="intUserSwitch" state="true" class="sapUiSmallMarginBeginEnd" change=".onInternalUserSwitchChange">
					<layoutData>
						<FlexItemData id="intUserFlexData" growFactor="1" />
					</layoutData>
				</Switch>
			</HBox>
		</HBox>
	</VBox>
</core:FragmentDefinition>