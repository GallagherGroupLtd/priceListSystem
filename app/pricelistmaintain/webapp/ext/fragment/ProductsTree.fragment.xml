<core:FragmentDefinition 
    xmlns:core="sap.ui.core" 
    xmlns="sap.m" 
    xmlns:t="sap.ui.table"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:macros="sap.fe.macros"
    xmlns:dnd="sap.ui.core.dnd">

    <VBox id="ProductListVBox" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/ProductList'}">
	
		<OverflowToolbar id="ProductListToolbar">
            <Title
                id="ProductListTitle"
                text="Product List" />
                
            <ToolbarSpacer id="ProductListToolbarSep_1" />


                <!-- <Button 
                    id="ProductListEditBtn" 
                    text="Edit"  
                    icon="sap-icon://edit"
                    enabled="false"
                    press="handler.onEdit"/> -->

                <Button
                    id="ProductListRefreshBtn"
                    text="Refresh Pricelist"
                    icon="sap-icon://refresh"
                    type="Emphasized"
                    enabled="true"
					visible="true"                    
                    press="handler.onRefreshPrice" />

                <Button
                    id="ProductListResetBtn"
                    text="Reset Pricelist"
                    icon="sap-icon://reset"
                    type="Emphasized"
                    enabled="true"
					visible="true"                         
                    press="handler.onResetPrice" />

                <ToggleButton
                    id="ProductListDeleteModeBtn"
                    text="Delete Mode"
                    icon="sap-icon://delete"
                    tooltip="Toggle delete mode"
                    press="handler.onToggleDeleteMode" />

                <Button
                    id="ProductListDeleteBtn"
                    text="Delete"
                    icon="sap-icon://delete"
                    enabled="false"
                    visible="false"
                    press="handler.onDelete" />

                <ToolbarSeparator id="ProductListToolbarSep_3" />

                <Button
                    id="ProductListExpandBtn"
                    text="Expand"
                    icon="sap-icon://expand-all"
                    tooltip="Expand all"
					visible="true"
                    press="handler.onExpand"/>

				<Button
                    id="ProductListCollapseBtn"
                    text="Collapse"
                    icon="sap-icon://collapse-all"
                    tooltip="Collapse all"
					visible="false"
                    press="handler.onCollapse"/>

                <Button
                    id="ProductListSortBtn"
                    icon="sap-icon://sort"
                    tooltip="Sort by Part Number"
                    press="handler.onSortProducts" />

                <Button
                    id="ProductListHierarchyFilterBtn"
                    icon="sap-icon://filter"
                    tooltip="Filter"
                    press="handler.onOpenHierarchyFilter"/>

                <!-- <Button 
                    id="ProductListChangeColumnBtn" 
                    icon="sap-icon://action-settings"
                    press=".onOpenColumnPopover"/> -->
                

                <!-- <MenuButton
                    id="ProductListExcelMenuBtn"
                    text="Excel"
                    icon="sap-icon://excel-attachment">
                    <menu>
                        <Menu id="ProductListExcelMenu">
                            <MenuItem id="ProductListExportID" text="Export" icon="sap-icon://excel-attachment" press=".onExportExcel"/>
                            <MenuItem id="ProductListUploadID" 
                                text="Upload" 
                                icon="sap-icon://upload" 
                                press=".onUploadExcel" 
                                visible="{= ${ui>/isActiveEntity} }"
                                enabled="{= ${ui>/isEditMode} }"/>
                        </Menu>
                    </menu>
                </MenuButton> -->

                <!-- <Button
                    id="ProductsListRefreshButton"
                    icon="sap-icon://refresh"
                    type="Emphasized"
                    press="handler.onRefresh" /> -->
        </OverflowToolbar>

        <t:TreeTable
            id="ProductPriceListTreeTable"
            selectionMode="Single"
            enableColumnReordering="true"
            enableColumnFreeze="true"
            rowSelectionChange="handler.onSelectionChange"
            width="100%"
            rows="{
                path: 'jsonModel>/productPriceList',
                parameters: { arrayNames: ['children'] } 
            }">
            <t:dragDropConfig>
                <dnd:DragDropInfo
                    id="ProductTreeDragDropInfo"
                    sourceAggregation="rows"
                    targetAggregation="rows"
                    dropPosition="OnOrBetween"
                    drop="handler.onDrop" />
            </t:dragDropConfig>            
            <t:columns>
                
                <t:Column id="ColCategoriesAndProducts" width="35%" >
                    <Label id="LblCategoriesAndProducts" text="Categories and Products" textAlign="Center" width="100%"/>
                    <t:template>
                        <Text id="TxtCategoriesAndProducts" text="{jsonModel>text}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column id="ColDescription" width="30%">
                    <Label id="LblDescription" text="Description" textAlign="Center" width="100%"/>
                    <t:template>
                        <Text id="TxtDescription" text="{= ${jsonModel>kind} === 'Product' ? ${jsonModel>MaterialDescription} : '' }" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column id="ColPriceCurrency" width="7.5%" hAlign="Center">
                    <Label id="LblPriceCurrency" text="Price (Currency)" textAlign="Center" width="100%"/>
                    <t:template>
                        <Text id="TxtPriceCurrency" text="{= ${jsonModel>kind} === 'Product' ? (${jsonModel>Price} || '') + ' ' + (${jsonModel>PriceUnit} || '') : '' }" />
                    </t:template>
                </t:Column>

                <t:Column id="ColValidity" width="12.5%" hAlign="Center">
                    <Label id="LblValidity" text="Validity" textAlign="Center" width="100%"/>
                    <t:template>
                        <Text id="TxtValidity" text="{= ${jsonModel>kind} === 'Product' ? ${jsonModel>MaterialStatusEffecDate} : '' }"/>
                    </t:template>
                </t:Column>

                <t:Column id="ColDiscountIndicator" width="7.5%" hAlign="Center">
                    <Label id="LblDiscountIndicator" text="Discount (Indicator)"/>
                    <t:template>
                        <Switch id="SwDiscountIndicator" state="false" 
                                visible="{= ${jsonModel>kind} === 'Product' }" 
                                customTextOn="Yes" 
                                customTextOff="No" />
                    </t:template>
                </t:Column>

                <t:Column id="ColThirdPartyIndicator" width="7.5%" hAlign="Center">
                    <Label id="LblThirdPartyIndicator" text="3rd Party (Indicator)"/>
                    <t:template>
                        <Switch id="SwThirdPartyIndicator" state="false" 
                                visible="{= ${jsonModel>kind} === 'Product' }" 
                                customTextOn="Yes" 
                                customTextOff="No" />
                    </t:template>
                </t:Column>

            </t:columns>
        </t:TreeTable>

    </VBox>
</core:FragmentDefinition>