<core:FragmentDefinition 
    xmlns:core="sap.ui.core" 
    xmlns="sap.m" 
    xmlns:t="sap.ui.table"
    xmlns:mvc="sap.ui.core.mvc" 
    xmlns:macros="sap.fe.macros">

    <VBox id="ProductListVBox" core:require="{ handler: 'pricelistapp/pricelistmaintain/ext/controller/ProductList'}">
	
		<OverflowToolbar id="ProductListToolbar">
            <Title
                id="ProductListTitle"
                text="Product List" />
                
            <ToolbarSpacer id="ProductListToolbarSep_1" />

                <Button
                    id="ProductListExpandBtn"
                    text="Expand"
                    icon="sap-icon://expand-all"
                    tooltip="Expand all"
					visible="true"
                    press="handler.onExpand"/>

				<Button
                    id="ProductListECollapseBtn"
                    text="Collapse"
                    icon="sap-icon://collapse-all"
                    tooltip="Collapse all"
					visible="false"
                    press="handler.onCollapse"/>

                <Button 
                    id="ProductListEditBtn" 
                    text="Edit"  
                    icon="sap-icon://edit"
                    enabled="false"
                    press="handler.onEdit"/>

                <Button
                    id="ProductListDeleteBtn"
                    text="Delete"
                    icon="sap-icon://delete"
                    enabled="false"
                    press="handler.onDelete" />

                <ToolbarSeparator id="ProductListToolbarSep_2" />

                <Button
                    id="ProductListSortBtn"
                    icon="sap-icon://sort"
                    tooltip="Sort by Part Number"
                    press="handler.onSortProducts" />

                <Button
                    id="ProductListHierarchyFilterBtn"
                    icon="sap-icon://filter"
                    tooltip="Filter"
                    press="handler.onOpenHierarchyFilter"/>

                <!-- <Button 
                    id="ProductListChangeColumnBtn" 
                    icon="sap-icon://action-settings"
                    press=".onOpenColumnPopover"/> -->
                
                <ToolbarSeparator id="ProductListToolbarSep_3" />

                <!-- <MenuButton
                    id="ProductListExcelMenuBtn"
                    text="Excel"
                    icon="sap-icon://excel-attachment">
                    <menu>
                        <Menu id="ProductListExcelMenu">
                            <MenuItem id="ProductListExportID" text="Export" icon="sap-icon://excel-attachment" press=".onExportExcel"/>
                            <MenuItem id="ProductListUploadID" 
                                text="Upload" 
                                icon="sap-icon://upload" 
                                press=".onUploadExcel" 
                                visible="{= ${ui>/isActiveEntity} }"
                                enabled="{= ${ui>/isEditMode} }"/>
                        </Menu>
                    </menu>
                </MenuButton> -->

                <Button
                    id="ProductsListRefreshButton"
                    icon="sap-icon://refresh"
                    type="Emphasized"
                    press="handler.onRefresh" />
        </OverflowToolbar>

        <t:TreeTable
            id="ProductPriceListTreeTable"
            selectionMode="Single"
            enableColumnReordering="true"
            enableColumnFreeze="true"
            rowSelectionChange="handler.onSelectionChange"
            width="100%"
            rows="{
                path: 'jsonModel>/productPriceList',
                parameters: { arrayNames: ['children'] } 
            }">
            <t:columns>
                
                <t:Column id="ColCategoriesAndProducts" width="22rem" >
                    <Label id="LblCategoriesAndProducts" text="Categories and Products" />
                    <t:template>
                        <Text id="TxtCategoriesAndProducts" text="{jsonModel>text}" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column id="ColDescription" width="25rem">
                    <Label id="LblDescription" text="Description"/>
                    <t:template>
                        <Text id="TxtDescription" text="{= ${jsonModel>kind} === 'Product' ? ${jsonModel>MaterialDescription} : '' }" wrapping="false" />
                    </t:template>
                </t:Column>

                <t:Column id="ColPriceCurrency" width="12rem">
                    <Label id="LblPriceCurrency" text="Price (Currency)"/>
                    <t:template>
                        <Text id="TxtPriceCurrency" text="{= ${jsonModel>kind} === 'Product' ? (${jsonModel>Price} || '') + ' ' + (${jsonModel>PriceUnit} || '') : '' }" />
                    </t:template>
                </t:Column>

                <t:Column id="ColValidity" width="12rem">
                    <Label id="LblValidity" text="Validity"/>
                    <t:template>
                        <Text id="TxtValidity" text="{= ${jsonModel>kind} === 'Product' ? ${jsonModel>MaterialStatusEffecDate} : '' }"/>
                    </t:template>
                </t:Column>

                <t:Column id="ColDiscountIndicator" width="10rem" hAlign="Center">
                    <Label id="LblDiscountIndicator" text="Discount (Indicator)"/>
                    <t:template>
                        <Switch id="SwDiscountIndicator" state="false" 
                                visible="{= ${jsonModel>kind} === 'Product' }" 
                                customTextOn="Yes" 
                                customTextOff="No" />
                    </t:template>
                </t:Column>

                <t:Column id="ColThirdPartyIndicator" width="10rem" hAlign="Center">
                    <Label id="LblThirdPartyIndicator" text="3rd Party (Indicator)"/>
                    <t:template>
                        <Switch id="SwThirdPartyIndicator" state="false" 
                                visible="{= ${jsonModel>kind} === 'Product' }" 
                                customTextOn="Yes" 
                                customTextOff="No" />
                    </t:template>
                </t:Column>

            </t:columns>
        </t:TreeTable>

    </VBox>
</core:FragmentDefinition>