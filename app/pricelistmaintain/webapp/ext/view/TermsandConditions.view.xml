
<mvc:View
    id="TermsandConditionsView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:m="sap.m"
    controllerName="pricelistapp.pricelistmaintain.ext.controller.TermsandConditions">

    <m:Toolbar id="TC_Toolbar" class="sapUiTinyMarginBottom">
        <m:Title id="TC_ToolbarTitle" text="Terms and Conditions" level="H4"/>
        <m:ToolbarSpacer id="TC_ToolbarSpacer"/>

        <m:Button
            id="TC_ExportBtn"
            text="Export"
            icon="sap-icon://excel-attachment"
            tooltip="Export Terms and Conditions"
            press=".onExportTermsToPDF"/>
    </m:Toolbar>

    <!-- Empty state -->
    <m:MessageStrip
        id="TC_EmptyStateStrip"
        text="No Terms &amp; Conditions maintained"
        type="Information"
        showIcon="true"
        visible="{= !${terms>/hasTerms} }"
        class="sapUiSmallMarginTop" />

    <!-- Main container (visible only when terms exist) -->
    <m:VBox
        id="TC_MainContainer"
        visible="{terms>/hasTerms}"
        class="sapUiSmallMarginTop">

        <m:VBox
            id="TC_HeaderTermsList"
            items="{terms>/headerTerms}">

            <m:items>
                <m:VBox id="TC_HeaderTermItem">
                    <m:Title
                        id="TC_HeaderTermTitle"
                        text="{terms>PricelistFieldName}"
                        level="H4"
                        wrapping="true"
                        class="sapUiLargeMarginTop sapUiTextBold" />

                    <m:Text
                        id="TC_HeaderTermContent"
                        text="{terms>TCContent}"
                        wrapping="true"
                        class="sapUiSmallMarginBottom" />
                </m:VBox>

                <m:VBox id="TC_DetailTermItem">
                    <m:Title
                        id="TC_DetailTermTitle"
                        text="{terms>PricelistFieldName}"
                        level="H5"
                        wrapping="true"
                        class="sapUiSmallMarginTop sapUiTextBold" />

                    <m:Text
                        id="TC_DetailTermContent"
                        text="{terms>TCContent}"
                        wrapping="true"
                        class="sapUiSmallMarginBottom" />
                </m:VBox>
            </m:items>
        </m:VBox>
    </m:VBox>
</mvc:View>