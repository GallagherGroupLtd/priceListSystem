<mvc:View
    id="ProductsTreeView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:t="sap.ui.table"
    xmlns:m="sap.m"
    xmlns:u="sap.ui.unified"
    controllerName="pricelistapp.pricelistmaintain.ext.controller.ProductsTree">
    <m:HBox id="ProductsTreeSection" width="100%" renderType="Bare" alignItems="Start">
        <m:VBox id="ProductsTreeVBox" width="100%" class="sapUiSmallMargin">
            <m:OverflowToolbar id="ProductsTreeToolbar">
                <m:Title
                    id="ProductsTreeTitle"
                    text="Product List" />
                
                <m:ToolbarSpacer id="ToolbarSep_1" />

                <m:Button
                    id="ProductsTreeExpandCollapseBtn"
                    text="Expand"
                    icon="sap-icon://expand-all"
                    tooltip="Expand all"
                    press=".onToggleExpandCollapse"/>

                <m:Button 
                    id="editBtn" 
                    text="Edit"  
                    icon="sap-icon://edit"
                    enabled="false"
                    press=".onEditNode"/>

                <m:Button
                    id="ProductsTreeDeleteBtn"
                    text="Delete"
                    icon="sap-icon://delete"
                    enabled="false"
                    press=".onDelete" />

                <m:ToolbarSeparator id="ToolbarSep_2" />

                <m:Button
                    id="ProductsTreeSortBtn"
                    icon="sap-icon://sort"
                    tooltip="Sort by Part Number"
                    press=".onSortProducts" />

                <m:Button
                    id="ProductsTreeHierarchyFilterBtn"
                    icon="sap-icon://filter"
                    tooltip="Filter"
                    press=".onOpenHierarchyFilter"/>

                <m:Button 
                    id="ChangeColumBtn" 
                    icon="sap-icon://action-settings"
                    press=".onOpenColumnPopover"/>
                
                <m:ToolbarSeparator id="ToolbarSep_3" />

                <m:MenuButton
                    id="ProductsTreeExcelMenuBtn"
                    text="Excel"
                    icon="sap-icon://excel-attachment">
                    <m:menu>
                        <m:Menu id="ExcelMenuID">
                            <m:MenuItem id="ExportID" text="Export" icon="sap-icon://excel-attachment" press=".onExportExcel"/>
                            <m:MenuItem id="UploadID" 
                                text="Upload" 
                                icon="sap-icon://upload" 
                                press=".onUploadExcel" 
                                visible="{= ${ui>/isActiveEntity} }"
                                enabled="{= ${ui>/isEditMode} }"/>
                        </m:Menu>
                    </m:menu>
                </m:MenuButton>

                <!-- <m:Button
                    id="ProductsTreeRefreshButton"
                    text="Go"
                    type="Emphasized"
                    press=".onRefresh" /> -->
            </m:OverflowToolbar>

            <t:TreeTable
                id="ProductsTreeTable"
                selectionMode="Single"
                enableColumnReordering="true"
                enableColumnFreeze="true"
                rowSelectionChange=".onSelectionChange"
                width="100%"
                rows="{
                    path: 'tree>/nodes',
                    parameters: { arrayNames: ['children'] } 
                }">
                <t:columns>
                    <t:Column id="ProductsTreeColNode" width="26rem" >
                        <m:Label id="ProductsTreeColNodeLabel" text="Node" />
                        <t:template>
                            <m:Text id="ProductsTreeNodeText" text="{tree>text}" wrapping="false" />
                        </t:template>
                    </t:Column>

                    <!-- <t:Column id="ProductsTreeColPartNumber" width="14rem" >
                        <m:Label id="ProductsTreeColPartNumberLabel" text="Part Number" />
                        <t:template>
                            <m:Text id="ProductsTreePartNumberText" text="{tree>PricelistPartNumber}" />
                        </t:template>
                    </t:Column> -->

                    <t:Column id="DescriptionColID" width="25%">
                        <m:Label id="DescriptionLabel" text="Description"/>
                        <t:template>
                            <m:Text id="DescriptionText" text="{path: 'tree>PartNumberDescrLong'}"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="PriceColID" width="20rem">
                        <m:Label id="PriceLabel" text="Price"/>
                        <t:template>
                            <m:Text id="PriceText" text="{= ${tree>Price} === 0 || ${tree>Price} === '0' ? '' : ${tree>Price} }" />
                        </t:template>
                    </t:Column>

                    <t:Column id="PriceUnitColID" width="15rem">
                        <m:Label id="PriceUnitLabel" text="Price Unit"/>
                        <t:template>
                            <m:Text id="PriceUnitText" text="{path:'tree>PriceUnit', targetType:'any'}"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colMaterialStat" visible="false">
                        <m:Label id="MaterialStatLabel" text="Material Status"/>
                        <t:template>
                            <m:Text id="inpMaterialStat" text="{tree>MaterialStatus}"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colMaterialStatEffDate" visible="false">
                        <m:Label id="MaterialStatEffDateLabel" text="Material Status Effective Date"/>
                        <t:template>
                            <m:Text id="MaterialStatEffectiveDate" text="{tree>MaterialStatusEffecDate}"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colDiscountRate" width="20rem">
                        <m:Label id="DisRateLabel" text="Discount Rate"/>
                        <t:template>
                            <m:Text id="inpDiscountRate" text="{tree>DiscountRate}"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colDiscountRateEffDate" width="20rem">
                        <m:Label id="DisRateEffDateLabel" text="Discount Effective Date"/>
                        <t:template>
                            <m:Text id="dpDiscountEffectiveDate" text="{tree>DiscountEffectiveDate}"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colMainCategoryTerms" width="25rem" visible="false">
                        <m:Label id="MainCategoryTermsLabel" text="Main Category Terms"/>
                        <t:template>
                            <m:Text id="MainCategoryTermsText" text="{tree>MainCategoryTermsandCond}" wrapping="true"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colSubCat1Terms" width="25rem" visible="false">
                        <m:Label id="SubCat1TermsLabel" text="Subcategory 1 Terms"/>
                        <t:template>
                            <m:Text id="SubCat1TermsText" text="{tree>SubCategory1TermsandCond}" wrapping="true"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colSubCat2Terms" width="25rem" visible="false">
                        <m:Label id="SubCat2TermsLabel" text="Subcategory 2 Terms"/>
                        <t:template>
                            <m:Text id="SubCat2TermsText" text="{tree>SubCategory2TermsandCond}" wrapping="true"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colSubCat3Terms" width="25rem" visible="false">
                        <m:Label id="SubCat3TermsLabel" text="Subcategory 3 Terms"/>
                        <t:template>
                            <m:Text id="SubCat3TermsText" text="{tree>SubCategory3TermsandCond}" wrapping="true"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colSubCat4Terms" width="25rem" visible="false">
                        <m:Label id="SubCat4TermsLabel" text="Subcategory 4 Terms"/>
                        <t:template>
                            <m:Text id="SubCat4TermsText" text="{tree>SubCategory4TermsandCond}" wrapping="true"/>
                        </t:template>
                    </t:Column>

                    <t:Column id="colSubCat5Terms" width="25rem" visible="false">
                        <m:Label id="SubCat5TermsLabel" text="Subcategory 5 Terms"/>
                        <t:template>
                            <m:Text id="SubCat5TermsText" text="{tree>SubCategory5TermsandCond}" wrapping="true"/>
                        </t:template>
                    </t:Column>
                </t:columns>
            </t:TreeTable>
        </m:VBox>


        <!-- <m:VBox id="TermsBox" width="30%" height="100%" class="sapUiSmallMargin">
            <m:HBox id="HBOXSpacer" height="0.5rem"/>
            <m:Title id="TermsandCondID" text="Terms and Conditions"/>
            <m:HBox id="HBOXSpacer2" height="0.5rem"/>

            <! TextArea: editable only when editing terms AND a node is selected >
            <m:TextArea 
                id="TermsContentBox"
                value=""
                width="100%"
                height="10rem"
                liveChange=".onTermsChanged"/>
        </m:VBox> -->

    </m:HBox>
</mvc:View>
